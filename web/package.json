{
  "name": "career-ops-web",
  "private": true,
  "version": "0.1.0",
  "description": "Browser dashboard for career-ops (localhost)",
  "scripts": {
    "dev": "concurrently -n api,ui -c cyan,magenta \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "tsx watch server/src/index.ts",
    "dev:ui": "npm --prefix ui run dev",
    "build": "npm run build:ui",
    "build:ui": "npm --prefix ui run build",
    "start": "node server/dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.63.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.1.0",
    "p-limit": "^6.2.0",
    "playwright": "^1.58.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
